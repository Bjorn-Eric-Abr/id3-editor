{
  "name": "id3",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "id3-edit": "./index.ts"
  },
  "scripts": {
    "start": "bun run index.ts",
    "build": "bun build --compile --minify index.ts --outfile id3-edit",
    "install:cli": "bun run build && mkdir -p ~/.bun/bin && ln -sf \"$PWD/id3-edit\" ~/.bun/bin/id3-edit",
    "uninstall:cli": "rm -f ~/.bun/bin/id3-editor"
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/sanitize-filename": "^1.6.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "enquirer": "^2.4.1",
    "node-id3": "^0.2.9",
    "sanitize-filename": "^1.6.4"
  }
}
