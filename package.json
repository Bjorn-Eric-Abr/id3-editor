{
  "name": "id3",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "id3-editor": "./index.ts"
  },
  "scripts": {
    "start": "bun run index.ts",
    "build": "bun build --compile --minify index.ts --outfile id3-editor",
    "install:cli": "bun run build && mkdir -p ~/.bun/bin && ln -sf \"$PWD/id3-editor\" ~/.bun/bin/id3-editor",
    "uninstall:cli": "rm -f ~/.bun/bin/id3-editor"
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/sanitize-filename": "^1.6.3",
    "markdownlint-cli": "^0.48.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "node-id3": "^0.2.9",
    "sanitize-filename": "^1.6.4"
  }
}
